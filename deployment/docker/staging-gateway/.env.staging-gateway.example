TA3000_ENVIRONMENT=staging-real-transport

# Live path flags are fail-closed by default if unset.
TA3000_ENABLE_LIVE_EXECUTION=
TA3000_ENABLE_STOCKSHARP_BRIDGE=
TA3000_ENABLE_QUIK_CONNECTOR=
TA3000_ENABLE_FINAM_TRANSPORT=

# Temporary env-only secrets (must be rotated regularly).
TA3000_STOCKSHARP_API_KEY=CHANGE_ME_STOCKSHARP_KEY
TA3000_STOCKSHARP_API_KEY_ROTATED_AT=2026-03-18T00:00:00Z
TA3000_FINAM_API_TOKEN=CHANGE_ME_FINAM_TOKEN
TA3000_FINAM_API_TOKEN_ROTATED_AT=2026-03-18T00:00:00Z

# Secret age policy.
TA3000_ENFORCE_LIVE_SECRETS=1
TA3000_ENFORCE_SECRET_AGE=1
TA3000_SECRET_MAX_AGE_DAYS=90

# Sidecar transport settings.
TA3000_SIDECAR_TRANSPORT=http
TA3000_SIDECAR_BASE_URL=http://stocksharp-sidecar-gateway:18081
TA3000_SIDECAR_TIMEOUT_SECONDS=3.0
TA3000_SIDECAR_STREAM_BATCH_SIZE=500
TA3000_SIDECAR_API_PREFIX=v1

# Runtime retry policy.
TA3000_RETRY_MAX_ATTEMPTS=3
TA3000_RETRY_BACKOFF_SECONDS=0.05

# Gateway canary controls.
TA3000_GATEWAY_KILL_SWITCH=0
TA3000_GATEWAY_ROUTE=stocksharp->quik->finam
