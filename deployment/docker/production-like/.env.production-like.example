TA3000_ENVIRONMENT=staging-live-sim
TA3000_ENABLE_LIVE_EXECUTION=1
TA3000_ENABLE_STOCKSHARP_BRIDGE=1
TA3000_ENABLE_QUIK_CONNECTOR=1
TA3000_ENABLE_FINAM_TRANSPORT=1
TA3000_ENFORCE_LIVE_SECRETS=1
TA3000_RETRY_MAX_ATTEMPTS=3
TA3000_RETRY_BACKOFF_SECONDS=0.05
TA3000_STOCKSHARP_API_KEY=CHANGE_ME_STOCKSHARP_KEY
TA3000_FINAM_API_TOKEN=CHANGE_ME_FINAM_TOKEN
TA3000_POSTGRES_DB=ta3000
TA3000_POSTGRES_USER=ta3000
TA3000_POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
