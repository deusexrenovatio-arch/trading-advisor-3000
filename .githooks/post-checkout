#!/usr/bin/env python
"""Keep Serena metadata initialized after checkout/worktree creation."""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


def _repo_root() -> Path:
    completed = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        check=False,
        capture_output=True,
        text=True,
    )
    if completed.returncode == 0 and completed.stdout.strip():
        return Path(completed.stdout.strip()).resolve()
    return Path.cwd().resolve()


def main() -> int:
    if os.getenv("TA3000_SKIP_SERENA_BOOTSTRAP", "").strip() == "1":
        return 0

    is_branch_checkout = len(sys.argv) >= 4 and sys.argv[3] == "1"
    is_new_checkout = len(sys.argv) >= 2 and set(sys.argv[1]) == {"0"}
    if not is_branch_checkout or not is_new_checkout:
        return 0

    repo_root = _repo_root()
    bootstrap_script = repo_root / "scripts" / "serena_worktree_bootstrap.py"
    if not bootstrap_script.exists():
        return 0

    completed = subprocess.run(
        [sys.executable, str(bootstrap_script), "--worktree", str(repo_root)],
        cwd=str(repo_root),
        check=False,
        capture_output=True,
        text=True,
    )
    if completed.returncode != 0:
        if completed.stdout:
            print(completed.stdout, file=sys.stderr, end="")
        if completed.stderr:
            print(completed.stderr, file=sys.stderr, end="")
        print(
            "[post-checkout] Serena worktree bootstrap did not complete. "
            "Run scripts/serena_worktree_bootstrap.py manually for details.",
            file=sys.stderr,
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
