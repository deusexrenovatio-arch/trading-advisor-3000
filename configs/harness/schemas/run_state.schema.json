{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness/run_state.schema.json",
  "title": "Harness Run State",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["initialized", "in_progress", "blocked", "completed", "failed"]},
    "current_phase_id": {"type": ["string", "null"]},
    "accepted_phase_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "rejected_phase_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "iteration_count": {"type": "integer", "minimum": 0},
    "last_event_sequence": {"type": "integer", "minimum": 0}
  },
  "required": [
    "run_id",
    "created_at",
    "updated_at",
    "status",
    "accepted_phase_ids",
    "rejected_phase_ids",
    "iteration_count",
    "last_event_sequence"
  ]
}
