{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness/phase_plan.schema.json",
  "title": "Phase Plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "phase_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "goal": {"type": "string", "minLength": 1},
          "scope_in": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "scope_out": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "dependencies": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "done_definition": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "acceptance_checks": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "required_tests": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "risk_notes": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "doc_outputs": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "allowed_change_surfaces": {"type": "array", "items": {"type": "string", "minLength": 1}}
        },
        "required": [
          "phase_id",
          "name",
          "goal",
          "scope_in",
          "scope_out",
          "requirement_ids",
          "dependencies",
          "done_definition",
          "acceptance_checks",
          "required_tests",
          "risk_notes",
          "doc_outputs",
          "allowed_change_surfaces"
        ]
      }
    }
  },
  "required": ["run_id", "generated_at", "phases"]
}
