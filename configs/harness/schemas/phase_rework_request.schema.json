{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness/phase_rework_request.schema.json",
  "title": "Phase Rework Request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "phase_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "required_fixes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "target_iteration": {"type": "integer", "minimum": 1}
  },
  "required": ["run_id", "phase_id", "generated_at", "reason", "required_fixes", "requirement_ids", "target_iteration"]
}
