{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness/traceability_matrix.schema.json",
  "title": "Traceability Matrix",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "requirement_id": {"type": "string", "minLength": 1},
          "phase_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "artifact_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "status": {"type": "string", "enum": ["covered", "partial", "missing"]},
          "notes": {"type": "string"}
        },
        "required": ["requirement_id", "phase_ids", "artifact_refs", "status"]
      }
    }
  },
  "required": ["run_id", "generated_at", "mappings"]
}
