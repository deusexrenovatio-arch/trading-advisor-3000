{
  "schema_version": 1,
  "profile_id": "stocksharp-quik-finam-staging-real-v1",
  "environment": "staging-real",
  "proof_class": "staging-real",
  "transport": {
    "base_url": "http://127.0.0.1:18101",
    "api_prefix": "v1",
    "timeout_seconds": 3.0,
    "stream_batch_size": 500
  },
  "finam_session_binding": {
    "base_url_env_var": "TA3000_FINAM_API_BASE_URL",
    "jwt_env_var": "TA3000_FINAM_API_TOKEN",
    "session_details_path": "/v1/sessions/details",
    "required_session_fields": [
      "created_at",
      "expires_at",
      "readonly",
      "account_ids"
    ]
  },
  "required_feature_flags": {
    "TA3000_ENABLE_LIVE_EXECUTION": "1",
    "TA3000_ENABLE_STOCKSHARP_BRIDGE": "1",
    "TA3000_ENABLE_QUIK_CONNECTOR": "1",
    "TA3000_ENABLE_FINAM_TRANSPORT": "1",
    "TA3000_ENFORCE_LIVE_SECRETS": "1"
  },
  "required_secret_env_vars": [
    "TA3000_STOCKSHARP_API_KEY",
    "TA3000_FINAM_API_TOKEN"
  ],
  "recovery": {
    "kill_switch_on_failure": true,
    "retry_max_attempts": 3,
    "retry_backoff_seconds": 0.05
  },
  "proof_operations": [
    "boot",
    "readiness",
    "kill_switch",
    "submit",
    "replace",
    "cancel",
    "updates",
    "reconciliation"
  ],
  "notes": "Secrets stay out of repo; this profile defines required env var names only."
}
