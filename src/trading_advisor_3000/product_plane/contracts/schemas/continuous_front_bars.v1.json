{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/continuous_front_bars.v1.json",
  "title": "ContinuousFrontBarsV1",
  "type": "object",
  "required": [
    "dataset_version",
    "roll_policy_version",
    "adjustment_policy_version",
    "instrument_id",
    "timeframe",
    "ts",
    "active_contract_id",
    "roll_epoch",
    "is_roll_bar",
    "is_first_bar_after_roll",
    "bars_since_roll",
    "native_open",
    "native_high",
    "native_low",
    "native_close",
    "native_volume",
    "native_open_interest",
    "continuous_open",
    "continuous_high",
    "continuous_low",
    "continuous_close",
    "adjustment_mode",
    "cumulative_additive_offset",
    "price_space",
    "causality_watermark_ts",
    "input_row_count",
    "created_at"
  ],
  "properties": {
    "dataset_version": {"type": "string", "minLength": 1},
    "roll_policy_version": {"type": "string", "minLength": 1},
    "adjustment_policy_version": {"type": "string", "minLength": 1},
    "instrument_id": {"type": "string", "minLength": 1},
    "timeframe": {"type": "string", "minLength": 1},
    "ts": {"type": "string", "minLength": 1},
    "active_contract_id": {"type": "string", "minLength": 1},
    "previous_contract_id": {"type": ["string", "null"]},
    "candidate_contract_id": {"type": ["string", "null"]},
    "roll_epoch": {"type": "integer", "minimum": 0},
    "roll_event_id": {"type": ["string", "null"]},
    "is_roll_bar": {"type": "boolean"},
    "is_first_bar_after_roll": {"type": "boolean"},
    "bars_since_roll": {"type": "integer", "minimum": 0},
    "native_open": {"type": "number"},
    "native_high": {"type": "number"},
    "native_low": {"type": "number"},
    "native_close": {"type": "number"},
    "native_volume": {"type": "integer", "minimum": 0},
    "native_open_interest": {"type": "integer", "minimum": 0},
    "continuous_open": {"type": "number"},
    "continuous_high": {"type": "number"},
    "continuous_low": {"type": "number"},
    "continuous_close": {"type": "number"},
    "adjustment_mode": {"type": "string", "enum": ["additive"]},
    "cumulative_additive_offset": {"type": "number"},
    "ratio_factor": {"type": ["number", "null"]},
    "price_space": {"type": "string", "minLength": 1},
    "causality_watermark_ts": {"type": "string", "minLength": 1},
    "input_row_count": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
