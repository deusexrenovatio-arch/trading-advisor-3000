{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/sidecar_cancel_intent_response.v1.json",
  "title": "SidecarCancelIntentResponseV1",
  "type": "object",
  "required": ["ack"],
  "properties": {
    "ack": {
      "type": "object",
