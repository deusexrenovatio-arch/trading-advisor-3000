        "intent_id": {"type": "string", "minLength": 1},
        "external_order_id": {"type": "string", "minLength": 1},
        "state": {"type": "string", "enum": ["canceled"]},
        "canceled_at": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
