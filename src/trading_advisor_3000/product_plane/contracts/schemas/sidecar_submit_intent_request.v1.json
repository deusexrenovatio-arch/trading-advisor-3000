{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/sidecar_submit_intent_request.v1.json",
  "title": "SidecarSubmitIntentRequestV1",
  "type": "object",
  "required": ["intent_id", "intent"],
  "properties": {
    "intent_id": {"type": "string", "minLength": 1},
    "intent": {
      "type": "object",
      "required": [
        "intent_id",
        "signal_id",
        "mode",
        "broker_adapter",
        "action",
        "contract_id",
        "qty",
        "price",
        "stop_price",
        "created_at"
      ],
      "properties": {
        "intent_id": {"type": "string", "minLength": 1},
        "signal_id": {"type": "string", "minLength": 1},
        "mode": {"type": "string", "enum": ["shadow", "paper", "live"]},
        "broker_adapter": {"type": "string", "minLength": 1},
        "action": {"type": "string", "enum": ["buy", "sell"]},
        "contract_id": {"type": "string", "minLength": 1},
        "qty": {"type": "integer", "minimum": 1},
        "price": {"type": "number", "exclusiveMinimum": 0},
        "stop_price": {"type": "number", "exclusiveMinimum": 0},
        "created_at": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
