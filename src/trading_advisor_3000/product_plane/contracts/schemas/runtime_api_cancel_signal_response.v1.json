{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/runtime_api_cancel_signal_response.v1.json",
  "title": "RuntimeApiCancelSignalResponseV1",
  "type": "object",
  "required": ["cancel_result", "active_signals", "publications"],
  "properties": {
    "cancel_result": {
      "type": "object",
      "required": ["signal", "publication"],
      "properties": {
        "signal": {
          "type": "object",
          "required": [
            "signal_id",
            "strategy_version_id",
            "contract_id",
            "mode",
            "side",
            "entry_price",
            "stop_price",
            "target_price",
            "confidence",
            "state",
            "opened_at",
            "updated_at"
          ],
          "properties": {
            "signal_id": {"type": "string", "minLength": 1},
            "strategy_version_id": {"type": "string", "minLength": 1},
            "contract_id": {"type": "string", "minLength": 1},
            "mode": {"type": "string", "enum": ["shadow", "paper", "live"]},
            "side": {"type": "string", "enum": ["long", "short"]},
            "entry_price": {"type": "number"},
            "stop_price": {"type": "number"},
            "target_price": {"type": "number"},
            "confidence": {"type": "number", "minimum": 0, "maximum": 1},
            "state": {"type": "string", "minLength": 1},
            "opened_at": {"type": "string", "minLength": 1},
            "updated_at": {"type": "string", "minLength": 1},
            "expires_at": {"type": ["string", "null"]},
            "publication_message_id": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        },
        "publication": {
          "type": "object",
          "required": [
            "publication_id",
            "signal_id",
            "channel",
            "message_id",
            "publication_type",
            "status",
            "published_at"
          ],
          "properties": {
            "publication_id": {"type": "string", "minLength": 1},
            "signal_id": {"type": "string", "minLength": 1},
            "channel": {"type": "string", "minLength": 1},
            "message_id": {"type": "string", "minLength": 1},
            "publication_type": {"type": "string", "enum": ["create", "edit", "close", "cancel"]},
            "status": {"type": "string", "enum": ["published", "closed", "canceled", "failed"]},
            "published_at": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "active_signals": {"type": "array", "items": {"type": "object"}},
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "publication_id",
          "signal_id",
          "channel",
          "message_id",
          "publication_type",
          "status",
          "published_at"
        ],
        "properties": {
          "publication_id": {"type": "string", "minLength": 1},
          "signal_id": {"type": "string", "minLength": 1},
          "channel": {"type": "string", "minLength": 1},
          "message_id": {"type": "string", "minLength": 1},
          "publication_type": {"type": "string", "enum": ["create", "edit", "close", "cancel"]},
          "status": {"type": "string", "enum": ["published", "closed", "canceled", "failed"]},
          "published_at": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
