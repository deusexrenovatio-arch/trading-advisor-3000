{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/runtime_api_replay_candidates_request.v1.json",
  "title": "RuntimeApiReplayCandidatesRequestV1",
  "type": "object",
  "required": ["candidates"],
  "properties": {
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "signal_id",
          "contract_id",
          "timeframe",
          "strategy_version_id",
          "mode",
          "side",
          "entry_ref",
          "stop_ref",
          "target_ref",
          "confidence",
          "ts_decision",
          "feature_snapshot"
        ],
        "properties": {
          "signal_id": {"type": "string", "minLength": 1},
          "contract_id": {"type": "string", "minLength": 1},
          "timeframe": {"type": "string", "enum": ["5m", "15m", "1h", "4h", "1d", "1w"]},
          "strategy_version_id": {"type": "string", "minLength": 1},
          "mode": {"type": "string", "enum": ["shadow", "paper", "live"]},
          "side": {"type": "string", "enum": ["long", "short"]},
          "entry_ref": {"type": "number"},
          "stop_ref": {"type": "number"},
          "target_ref": {"type": "number"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "ts_decision": {"type": "string", "minLength": 1},
          "feature_snapshot": {
            "type": "object",
            "required": ["dataset_version", "snapshot_id"],
            "properties": {
              "dataset_version": {"type": "string", "minLength": 1},
              "snapshot_id": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
