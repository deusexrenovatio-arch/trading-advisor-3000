{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/continuous_front_roll_events.v1.json",
  "title": "ContinuousFrontRollEventsV1",
  "type": "object",
  "required": [
    "dataset_version",
    "roll_policy_version",
    "adjustment_policy_version",
    "instrument_id",
    "timeframe",
    "roll_event_id",
    "roll_sequence",
    "old_contract_id",
    "new_contract_id",
    "decision_ts",
    "effective_ts",
    "first_new_bar_ts",
    "last_old_bar_ts",
    "old_reference_price",
    "new_reference_price",
    "additive_gap",
    "old_reference_source",
    "new_reference_source",
    "roll_reason",
    "causality_watermark_ts",
    "created_at"
  ],
  "properties": {
    "dataset_version": {"type": "string", "minLength": 1},
    "roll_policy_version": {"type": "string", "minLength": 1},
    "adjustment_policy_version": {"type": "string", "minLength": 1},
    "instrument_id": {"type": "string", "minLength": 1},
    "timeframe": {"type": "string", "minLength": 1},
    "roll_event_id": {"type": "string", "minLength": 1},
    "roll_sequence": {"type": "integer", "exclusiveMinimum": 0},
    "old_contract_id": {"type": "string", "minLength": 1},
    "new_contract_id": {"type": "string", "minLength": 1},
    "decision_ts": {"type": "string", "minLength": 1},
    "effective_ts": {"type": "string", "minLength": 1},
    "first_new_bar_ts": {"type": "string", "minLength": 1},
    "last_old_bar_ts": {"type": "string", "minLength": 1},
    "old_reference_price": {"type": "number"},
    "new_reference_price": {"type": "number"},
    "additive_gap": {"type": "number"},
    "ratio_gap": {"type": ["number", "null"]},
    "old_reference_source": {"type": "string", "minLength": 1},
    "new_reference_source": {"type": "string", "minLength": 1},
    "roll_reason": {"type": "string", "minLength": 1},
    "causality_watermark_ts": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
