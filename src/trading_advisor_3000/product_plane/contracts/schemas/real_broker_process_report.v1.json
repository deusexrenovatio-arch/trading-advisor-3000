{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/real_broker_process_report.v1.json",
  "title": "RealBrokerProcessReportV1",
  "type": "object",
  "required": [
    "schema_version",
    "capability",
    "capability_brief",
    "route_signal",
    "proof_class",
    "generated_at",
    "run_id",
    "git_sha",
    "commands",
    "artifacts",
    "real_bindings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "capability_brief": {
      "type": "string",
      "minLength": 1
    },
    "route_signal": {
      "type": "string",
      "const": "worker:capability-only"
    },
    "proof_class": {
      "type": "string",
      "const": "staging-real"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "git_sha": {
      "type": "string",
      "minLength": 7
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "command",
          "return_code",
          "started_at",
          "finished_at",
          "duration_sec",
          "stdout_path",
          "stderr_path"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "return_code": {
            "type": "integer"
          },
          "started_at": {
            "type": "string",
            "minLength": 1
          },
          "finished_at": {
            "type": "string",
            "minLength": 1
          },
          "duration_sec": {
            "type": "number",
            "minimum": 0
          },
          "stdout_path": {
            "type": "string",
            "minLength": 1
          },
          "stderr_path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "run_dir",
        "environment",
        "build",
        "test",
        "publish",
        "smoke",
        "smoke_validation",
        "connector_health_validation",
        "connector_session_proof",
        "rollout",
        "recovery_validation",
        "negative_tests",
        "hashes_json",
        "hashes_sha256",
        "hash_validation",
        "publish_dir"
      ],
      "properties": {
        "run_dir": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "build": {
          "type": "string",
          "minLength": 1
        },
        "test": {
          "type": "string",
          "minLength": 1
        },
        "publish": {
          "type": "string",
          "minLength": 1
        },
        "smoke": {
          "type": "string",
          "minLength": 1
        },
        "smoke_validation": {
          "type": "string",
          "minLength": 1
        },
        "connector_health_validation": {
          "type": "string",
          "minLength": 1
        },
        "connector_session_proof": {
          "type": "string",
          "minLength": 1
        },
        "rollout": {
          "type": "string",
          "minLength": 1
        },
        "recovery_validation": {
          "type": "string",
          "minLength": 1
        },
        "negative_tests": {
          "type": "string",
          "minLength": 1
        },
        "hashes_json": {
          "type": "string",
          "minLength": 1
        },
        "hashes_sha256": {
          "type": "string",
          "minLength": 1
        },
        "hash_validation": {
          "type": "string",
          "minLength": 1
        },
        "publish_dir": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "real_bindings": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
