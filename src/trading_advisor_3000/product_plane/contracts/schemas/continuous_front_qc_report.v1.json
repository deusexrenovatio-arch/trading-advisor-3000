{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/continuous_front_qc_report.v1.json",
  "title": "ContinuousFrontQcReportV1",
  "type": "object",
  "required": [
    "dataset_version",
    "roll_policy_version",
    "adjustment_policy_version",
    "instrument_id",
    "timeframe",
    "run_id",
    "started_at",
    "completed_at",
    "input_row_count",
    "output_row_count",
    "roll_event_count",
    "missing_active_bar_count",
    "duplicate_key_count",
    "timeline_error_count",
    "ohlc_error_count",
    "negative_volume_oi_count",
    "missing_reference_price_count",
    "future_causality_violation_count",
    "gap_abs_max",
    "gap_abs_mean",
    "status"
  ],
  "properties": {
    "dataset_version": {"type": "string", "minLength": 1},
    "roll_policy_version": {"type": "string", "minLength": 1},
    "adjustment_policy_version": {"type": "string", "minLength": 1},
    "instrument_id": {"type": "string", "minLength": 1},
    "timeframe": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "started_at": {"type": "string", "minLength": 1},
    "completed_at": {"type": "string", "minLength": 1},
    "input_row_count": {"type": "integer", "minimum": 0},
    "output_row_count": {"type": "integer", "minimum": 0},
    "roll_event_count": {"type": "integer", "minimum": 0},
    "missing_active_bar_count": {"type": "integer", "minimum": 0},
    "duplicate_key_count": {"type": "integer", "minimum": 0},
    "timeline_error_count": {"type": "integer", "minimum": 0},
    "ohlc_error_count": {"type": "integer", "minimum": 0},
    "negative_volume_oi_count": {"type": "integer", "minimum": 0},
    "missing_reference_price_count": {"type": "integer", "minimum": 0},
    "future_causality_violation_count": {"type": "integer", "minimum": 0},
    "gap_abs_max": {"type": "number", "minimum": 0},
    "gap_abs_mean": {"type": "number", "minimum": 0},
    "blocked_reason": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["PASS", "BLOCKED", "SKIP"]}
  },
  "additionalProperties": false
}
