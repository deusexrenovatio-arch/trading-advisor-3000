{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/gold_feature_snapshot.v1.json",
  "title": "GoldFeatureSnapshotV1",
  "type": "object",
  "required": [
    "snapshot_id",
    "contract_id",
    "instrument_id",
    "timeframe",
    "ts",
    "feature_set_version",
    "regime",
    "atr",
    "ema_fast",
    "ema_slow",
    "donchian_high",
    "donchian_low",
    "rvol",
    "features_json"
  ],
  "properties": {
    "snapshot_id": {"type": "string", "minLength": 1},
    "contract_id": {"type": "string", "minLength": 1},
    "instrument_id": {"type": "string", "minLength": 1},
    "timeframe": {"type": "string", "enum": ["5m", "15m", "1h", "4h", "1d", "1w"]},
    "ts": {"type": "string", "minLength": 1},
    "feature_set_version": {"type": "string", "minLength": 1},
    "regime": {"type": "string", "minLength": 1},
    "atr": {"type": "number", "minimum": 0},
    "ema_fast": {"type": "number"},
    "ema_slow": {"type": "number"},
    "donchian_high": {"type": "number"},
    "donchian_low": {"type": "number"},
    "rvol": {"type": "number", "minimum": 0},
    "last_close": {"type": "number"},
    "last_volume": {"type": "number", "minimum": 0},
    "atr_14": {"type": "number", "minimum": 0},
    "natr_14": {"type": "number", "minimum": 0},
    "ema_12": {"type": "number"},
    "ema_26": {"type": "number"},
    "sma_20": {"type": "number"},
    "sma_50": {"type": "number"},
    "rsi_14": {"type": "number"},
    "macd": {"type": "number"},
    "macd_signal": {"type": "number"},
    "macd_hist": {"type": "number"},
    "bb_width": {"type": "number", "minimum": 0},
    "bb_percent_b": {"type": "number"},
    "adx_14": {"type": "number"},
    "stoch_k": {"type": "number"},
    "stoch_d": {"type": "number"},
    "cci_20": {"type": "number"},
    "willr_14": {"type": "number"},
    "mom_10": {"type": "number"},
    "roc_10": {"type": "number"},
    "mfi_14": {"type": "number"},
    "donchian_position": {"type": "number"},
    "trend_score": {"type": "number"},
    "momentum_score": {"type": "number"},
    "volatility_score": {"type": "number"},
    "volume_pressure": {"type": "number"},
    "supertrend_direction": {"type": "number"},
    "breakout_state": {"type": "string", "enum": ["lower", "inside", "upper"]},
    "features_json": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "string", "boolean", "null"]
      }
    }
  },
  "additionalProperties": false
}
