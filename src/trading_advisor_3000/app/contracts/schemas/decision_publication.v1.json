{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/decision_publication.v1.json",
  "title": "DecisionPublicationV1",
  "type": "object",
  "required": [
    "signal_id",
    "channel",
    "message_id",
    "status",
    "published_at"
  ],
  "properties": {
    "signal_id": {"type": "string", "minLength": 1},
    "channel": {"type": "string", "minLength": 1},
    "message_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["candidate", "published", "closed", "canceled"]},
    "published_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
