{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/sidecar_replace_intent_request.v1.json",
  "title": "SidecarReplaceIntentRequestV1",
  "type": "object",
  "required": ["intent_id", "new_qty", "new_price", "replaced_at"],
  "properties": {
    "intent_id": {"type": "string", "minLength": 1},
    "new_qty": {"type": "integer", "minimum": 1},
    "new_price": {"type": "number", "exclusiveMinimum": 0},
    "replaced_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
