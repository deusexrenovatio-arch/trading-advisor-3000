{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/staging_rollout_report.v1.json",
  "title": "StagingRolloutReportV1",
  "type": "object",
  "required": ["generated_at", "status", "base_url", "account_id", "dry_run", "stages"],
  "properties": {
    "generated_at": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["ok", "failed"]},
    "base_url": {"type": "string", "minLength": 1},
    "account_id": {"type": "string", "minLength": 1},
    "dry_run": {"type": "boolean"},
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stage", "status", "details"],
        "properties": {
          "stage": {"type": "string", "enum": ["connectivity", "canary", "batch"]},
          "status": {"type": "string", "enum": ["ok", "failed", "planned"]},
          "details": {"type": "object"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
