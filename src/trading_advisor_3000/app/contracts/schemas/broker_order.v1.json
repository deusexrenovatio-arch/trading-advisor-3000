{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/broker_order.v1.json",
  "title": "BrokerOrderV1",
  "type": "object",
  "required": [
    "broker_order_id",
    "intent_id",
    "broker",
    "state",
    "submitted_at",
    "updated_at"
  ],
  "properties": {
    "broker_order_id": {"type": "string", "minLength": 1},
    "intent_id": {"type": "string", "minLength": 1},
    "external_order_id": {"type": ["string", "null"], "minLength": 1},
    "broker": {"type": "string", "minLength": 1},
    "state": {
      "type": "string",
      "enum": ["new", "submitted", "replaced", "partially_filled", "filled", "canceled", "rejected"]
    },
    "submitted_at": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
