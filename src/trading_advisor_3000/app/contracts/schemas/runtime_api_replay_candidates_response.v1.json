{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/runtime_api_replay_candidates_response.v1.json",
  "title": "RuntimeApiReplayCandidatesResponseV1",
  "type": "object",
  "required": ["replay_report", "active_signals", "publications"],
  "properties": {
    "replay_report": {
      "type": "object",
      "required": [
        "accepted",
        "rejected",
        "published",
        "edited",
        "active_signals",
        "accepted_signal_ids",
        "accepted_unique_signals",
        "accepted_candidates",
        "rejected_signal_ids",
        "rejection_reasons",
        "context_slices_total",
        "context_slices_by_kind",
        "signals_with_context"
      ],
      "properties": {
        "accepted": {"type": "integer", "minimum": 0},
        "rejected": {"type": "integer", "minimum": 0},
        "published": {"type": "integer", "minimum": 0},
        "edited": {"type": "integer", "minimum": 0},
        "active_signals": {"type": "integer", "minimum": 0},
        "accepted_signal_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "accepted_unique_signals": {"type": "integer", "minimum": 0},
        "accepted_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signal_id", "candidate_id"],
            "properties": {
              "signal_id": {"type": "string", "minLength": 1},
              "candidate_id": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "rejected_signal_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "rejection_reasons": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "context_slices_total": {"type": "integer", "minimum": 0},
        "context_slices_by_kind": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "signals_with_context": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "active_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "signal_id",
          "strategy_version_id",
          "contract_id",
          "mode",
          "side",
          "entry_price",
          "stop_price",
          "target_price",
          "confidence",
          "state",
          "opened_at",
          "updated_at"
        ],
        "properties": {
          "signal_id": {"type": "string", "minLength": 1},
          "strategy_version_id": {"type": "string", "minLength": 1},
          "contract_id": {"type": "string", "minLength": 1},
          "mode": {"type": "string", "enum": ["shadow", "paper", "live"]},
          "side": {"type": "string", "enum": ["long", "short"]},
          "entry_price": {"type": "number"},
          "stop_price": {"type": "number"},
          "target_price": {"type": "number"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "state": {"type": "string", "minLength": 1},
          "opened_at": {"type": "string", "minLength": 1},
          "updated_at": {"type": "string", "minLength": 1},
          "expires_at": {"type": ["string", "null"]},
          "publication_message_id": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "publication_id",
          "signal_id",
          "channel",
          "message_id",
          "publication_type",
          "status",
          "published_at"
        ],
        "properties": {
          "publication_id": {"type": "string", "minLength": 1},
          "signal_id": {"type": "string", "minLength": 1},
          "channel": {"type": "string", "minLength": 1},
          "message_id": {"type": "string", "minLength": 1},
          "publication_type": {"type": "string", "enum": ["create", "edit", "close", "cancel"]},
          "status": {"type": "string", "enum": ["published", "closed", "canceled", "failed"]},
          "published_at": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
